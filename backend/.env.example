# ─────────────────────────────────────────────────────────────────────────
# Backend environment — copy to `.env` for local development.
#   cp backend/.env.example backend/.env
# `.env` is gitignored. In production these are injected by the platform.
# The dev script (./dev.sh) sources this file automatically.
# ─────────────────────────────────────────────────────────────────────────

# Run mode. Use `development` locally — it relaxes the prod-only origin checks.
FLASK_ENV=development

# Port the Flask API listens on. The Vite dev proxy expects 8000.
PORT=8000

# REQUIRED — the app refuses to boot without this. Any value works locally.
ADMIN_PASSWORD=devlocal

# OPTIONAL — enables free-text Josephine chat (the scripted flows work without
# it). Leave blank to run offline; set to a real key to enable LLM replies.
# ANTHROPIC_API_KEY=sk-ant-...

# OPTIONAL — only enforced when FLASK_ENV=production. Comma-separated origins.
# ALLOWED_ORIGINS=https://your-domain.com
